# --- Database ---
# Runtime connection uses a restricted, NON-owner role so Postgres RLS is
# actually enforced (owners/superusers bypass RLS). The role is created by the
# RLS migration (0001_rls.sql).
DATABASE_URL="postgres://app_user:app_user@localhost:5432/synced_docs"
# Admin/owner connection, used only by drizzle-kit for migrations + role setup.
DATABASE_ADMIN_URL="postgres://postgres:postgres@localhost:5432/synced_docs"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"

# --- Realtime WebSocket server ---
# Public URL the browser connects to; the server binds to WS_PORT.
NEXT_PUBLIC_WS_URL="ws://localhost:1234"
WS_PORT="1234"

# --- AI (Google Gemini) — optional. App fully works without it. ---
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
